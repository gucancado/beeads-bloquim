# ---- Banco de dados ----
DATABASE_URL=postgresql://bloquim:bloquim@localhost:5432/bloquim

# ---- Portas ----
# api-server e mindtask-app rodam em terminais separados.
# Cada um lê PORT individualmente (script dev exporta a variável correta).
API_PORT=5000
WEB_PORT=3000

# ---- Auth / encryption ----
# JWT_SECRET: hex aleatório (>= 32 bytes). Gere com: openssl rand -hex 32
JWT_SECRET=replace_me_with_openssl_rand_hex_32
# INTEGRATIONS_ENCRYPTION_KEY: base64 de 32 bytes. Gere com: openssl rand -base64 32
INTEGRATIONS_ENCRYPTION_KEY=replace_me_with_openssl_rand_base64_32

# ---- Frontend (Vite) ----
BASE_PATH=/
VITE_API_BASE_URL=http://localhost:5000

# ---- CORS ----
# Origens permitidas (lista separada por vírgula). Inclua o(s) domínio(s) do frontend.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- Logging ----
NODE_ENV=development
LOG_LEVEL=debug

# ---- Storage ----
# disabled = upload retorna 503. Use enquanto a integração com Supabase Storage não estiver pronta.
# supabase = usa Supabase Storage (preencher SUPABASE_URL e SUPABASE_SERVICE_ROLE_KEY)
STORAGE_PROVIDER=disabled
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET_ATTACHMENTS=bloquim-attachments
SUPABASE_STORAGE_BUCKET_AVATARS=bloquim-avatars
SUPABASE_STORAGE_BUCKET_PUBLIC=bloquim-public-assets

# ---- Google Calendar ----
# false = endpoints de google-calendar respondem 503. Mantenha enquanto não cadastrar projeto OAuth.
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5000/api/integrations/google-calendar/callback
