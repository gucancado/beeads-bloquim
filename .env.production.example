# ---------------------------------------------------------------------------
# Production env template — Bloquim @ Hetzner / Easypanel
# ---------------------------------------------------------------------------
# Copy values into the Easypanel "Environment" panel of the bloquim-api service.
# Frontend (mindtask-app) reads NOTHING from runtime env in prod — Vite bakes
# everything at build time (BASE_PATH=/), so it has no env panel to fill.
# ---------------------------------------------------------------------------

# === Banco de dados ===
# Postgres self-hosted no MESMO Easypanel (template oficial). bloquim-api e
# bloquim-db ficam no mesmo Docker network — host = nome do serviço.
# Substitua <DB_PASSWORD> pela senha gerada quando criar o serviço.
DATABASE_URL=postgresql://postgres:<DB_PASSWORD>@bloquim-db:5432/bloquim

# === Portas ===
API_PORT=5000

# === Auth / encryption ===
# Gere fresh para prod — NÃO reutilize secrets do dev.
#   JWT_SECRET:                  openssl rand -hex 32
#   INTEGRATIONS_ENCRYPTION_KEY: openssl rand -base64 32
JWT_SECRET=<openssl rand -hex 32>
INTEGRATIONS_ENCRYPTION_KEY=<openssl rand -base64 32>

# === CORS ===
# Same-origin (path routing) → o navegador NÃO envia Origin em requests do mesmo
# domínio, mas mantenha o domain aqui pra requests cross-origin de ferramentas
# externas (ex: integrações, mobile app futuro).
ALLOWED_ORIGINS=https://bloquim.beeads.com.br

# === Logging ===
NODE_ENV=production
LOG_LEVEL=info

# === Storage (Cloudflare R2 — S3-compatible) ===
# Mantenha `disabled` até a Fase 3 (StorageService abstrato) ser implementada.
# Quando implementar, troque para `s3` e preencha o resto.
STORAGE_PROVIDER=disabled

# Endpoint R2: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# Pegue o ACCOUNT_ID em Cloudflare → R2 → Overview (canto superior direito).
S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_REGION=auto
S3_FORCE_PATH_STYLE=true

# Credenciais geradas em Cloudflare → R2 → Manage R2 API tokens → Create token
# (escopo: Object Read & Write, com acesso aos 3 buckets abaixo)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Buckets criados em Cloudflare → R2 → Create bucket
S3_BUCKET_ATTACHMENTS=bloquim-attachments
S3_BUCKET_AVATARS=bloquim-avatars
S3_BUCKET_PUBLIC=bloquim-public-assets

# === Google Calendar ===
# Set GOOGLE_CALENDAR_ENABLED=true depois de cadastrar o app no Google Cloud
# Console com este redirect URI:
#   https://bloquim.beeads.com.br/api/integrations/google-calendar/callback
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://bloquim.beeads.com.br/api/integrations/google-calendar/callback
